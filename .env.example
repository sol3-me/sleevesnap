# ──────────────────────────────────────────────────────────────────────────────
# sleevesnap – environment variables
# Copy this file to .env and fill in the required values.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────

# Port the combined app listens on in production/Docker, where the built
# frontend and the API are served together from one process.
PORT=3000

# Port the Express API listens on for LOCAL DEV ONLY, where you run the
# frontend (`npm run dev`, always :3000) and the backend
# (`npm run dev:server`) as two separate processes. Vite's dev-server proxy
# also reads this to know where to forward /api and /covers requests.
# Leave this different from PORT above, or the backend will try to bind the
# same port Vite is already using and fail to start.
SERVER_PORT=3001

# Full public URL of the app (used to build cover-art URLs with local storage)
PUBLIC_URL=http://localhost:3000

# MusicBrainz app identifier sent in User-Agent (required by MusicBrainz API)
MUSICBRAINZ_APP_NAME=sleevesnap

# ── Storage ───────────────────────────────────────────────────────────────────
# Cover-art blobs are stored on the local filesystem (a Docker volume),
# served by Express. No external object storage is used — self-hosted and
# local-first by design; a future Firebase migration would replace this.

# Path inside the container where cover-art files are stored
STORAGE_LOCAL_PATH=/data/covers

# ── SQLite ────────────────────────────────────────────────────────────────────
# Path inside the container; the directory must exist and be writable.
CACHE_DB_PATH=/data/cache.db

# ── Optional API integrations ─────────────────────────────────────────────────
DISCOGS_TOKEN=
LASTFM_API_KEY=

# ── AI Vision (optional; single-sleeve identification fallback) ──────────────
# When pHash finds no local match, the server can call a vision API to guess
# the artist/title, then validate the guess against MusicBrainz. Leave both
# keys blank to disable this entirely (falls back to manual search, as today).
GEMINI_API_KEY=
OPENAI_API_KEY=

# Global daily cap on vision-identification calls (shared across all users;
# this app has no per-user accounts yet). Default: 5.
VISION_DAILY_LIMIT=5

# Optional secret; when a request supplies this value via the
# X-Vision-Admin-Key header, the daily cap is bypassed for that request.
# Leave blank to disable the bypass entirely (safe default).
# TODO, change this so that it's associated to an ACCOUNT when we introduce accounts as to make it easier to override.
VISION_ADMIN_KEY=

# ── Firebase Authentication ───────────────────────────────────────────────────
# All API routes require a signed-in Firebase user. Server-side verification
# only needs the project id — no service-account JSON.
FIREBASE_PROJECT_ID=

# Web app config for the browser (Firebase console → Project settings → Your
# apps → Web app). These are public client identifiers, not secrets.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
