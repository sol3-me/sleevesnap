# ──────────────────────────────────────────────────────────────────────────────
# sleevesnap – environment variables
# Copy this file to .env and fill in the required values.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────

PORT=3000

# Full public URL of the app (used to build cover-art URLs with local storage)
PUBLIC_URL=http://localhost:3000

# MusicBrainz app identifier sent in User-Agent (required by MusicBrainz API)
MUSICBRAINZ_APP_NAME=sleevesnap

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER controls which backend is used for cover-art blobs.
#
#   local  – files stored on a Docker volume, served by Express  (default)
#   s3     – S3-compatible object storage (MinIO, AWS S3, Cloudflare R2, etc.)
#
STORAGE_PROVIDER=s3

# Path inside the container used when STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/data/covers

# ── MinIO / S3-compatible storage ─────────────────────────────────────────────
# These values are used both by the app (S3Provider) and by the MinIO container.
# For the default compose profile (app + MinIO) the defaults below work out
# of the box.  Change them before exposing MinIO to the internet.

S3_ENDPOINT=http://minio:9000
S3_BUCKET=sleevesnap-covers
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Override the public base URL for objects stored in S3 / MinIO.
# Leave blank to derive from S3_ENDPOINT.
S3_PUBLIC_URL=

# MinIO web UI ports (optional, change if there are port conflicts)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── SQLite ────────────────────────────────────────────────────────────────────
# Path inside the container; the directory must exist and be writable.
CACHE_DB_PATH=/data/cache.db

# ── Optional API integrations ─────────────────────────────────────────────────
DISCOGS_TOKEN=
LASTFM_API_KEY=

# ── AI Vision (optional; single-sleeve identification fallback) ──────────────
# When pHash finds no local match, the server can call a vision API to guess
# the artist/title, then validate the guess against MusicBrainz. Leave both
# keys blank to disable this entirely (falls back to manual search, as today).
GEMINI_API_KEY=
OPENAI_API_KEY=

# Global daily cap on vision-identification calls (shared across all users;
# this app has no per-user accounts yet). Default: 5.
VISION_DAILY_LIMIT=5

# Optional secret; when a request supplies this value via the
# X-Vision-Admin-Key header, the daily cap is bypassed for that request.
# Leave blank to disable the bypass entirely (safe default).
VISION_ADMIN_KEY=
