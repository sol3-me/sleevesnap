{
	"name": "sleevesnap",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:server": "tsx watch server/index.ts",
		"build": "vite build && tsc -p tsconfig.server.json",
		"test": "npm run test:auth && npm run test:search && npm run test:scan && npm run test:scans && npm run test:scan-history && npm run test:collection && npm run test:vision && npm run test:db && npm run test:rate-limits && npm run test:vinyl-service && npm run test:filters && npm run test:ai-guess && npm run test:api-fetch && npm run test:signup-validation && npm run test:auth-errors && npm run test:landing-covers && npm run test:landing-route && npm run test:landing-wall && npm run test:landing-demo",
		"test:auth": "tsx --test server/auth.test.ts",
		"test:search": "tsx --test server/routes/search.test.ts",
		"test:scan": "tsx --test server/routes/scan.test.ts",
		"test:scans": "tsx --test server/routes/scans.test.ts",
		"test:scan-history": "tsx --test server/routes/scanHistory.test.ts",
		"test:collection": "tsx --test server/routes/collection.test.ts",
		"test:vision": "tsx --test server/services/visionProvider/index.test.ts",
		"test:db": "tsx --test server/db.test.ts",
		"test:rate-limits": "tsx --test server/rateLimiters.test.ts",
		"test:vinyl-service": "tsx --test services/vinylService.test.ts",
		"test:filters": "tsx --test lib/filters.test.ts",
		"test:ai-guess": "tsx --test lib/aiGuessFields.test.ts",
		"test:api-fetch": "tsx --test lib/apiFetch.test.ts",
		"test:signup-validation": "tsx --test lib/signupValidation.test.ts",
		"test:auth-errors": "tsx --test lib/authErrors.test.ts",
		"test:landing-covers": "tsx --test server/services/landingCovers.test.ts",
		"test:landing-route": "tsx --test server/routes/landing.test.ts",
		"test:landing-wall": "tsx --test lib/landingWall.test.ts",
		"test:landing-demo": "tsx --test lib/landingDemo.test.ts",
		"warm:landing": "tsx server/scripts/warmLandingPool.ts",
		"preview": "vite preview",
		"start": "node dist-server/index.js"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/react-query": "5.101.2",
		"@tanstack/react-router": "1.170.17",
		"better-sqlite3": "^12.8.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"express-rate-limit": "^8.3.2",
		"firebase": "^12.16.0",
		"firebase-admin": "^13.10.0",
		"jimp": "^1.6.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"sonner": "^2.0.7",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"@types/node": "^22.14.0",
		"@vitejs/plugin-react": "^5.0.0",
		"tsx": "^4.21.0",
		"typescript": "~5.8.2",
		"vite": "^6.2.0"
	},
	"overrides": {
		"simple-xml-to-json": "1.2.2"
	}
}
